{
  "name": "server",
  "module": "index.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "start": "bash -c \"./db/init.sh\" && bun --watch index.ts",
    "dev": "concurrently \"bun run start\" \"bun run db-studio\"",
    "setup-dev": "create and seed the db",
    "db-create": "bash -c \"./db/init.sh\" && bunx drizzle-kit generate --config \"db/drizzle.config.ts\" && bunx drizzle-kit push --config \"db/drizzle.config.ts\"",
    "db-reset": "docker rm -f my_earth_db || true && bun run db-create && bun run db-seed",
    "db-seed": "bun 'db/seed.ts'",
    "db-studio": "bunx drizzle-kit studio --config \"db/drizzle.config.ts\""
  },
  "devDependencies": {
    "@types/bun": "latest",
    "concurrently": "^9.1.2",
    "drizzle-kit": "^0.31.1"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "drizzle-orm": "^0.43.1",
    "drizzle-seed": "^0.3.1",
    "hono": "^4.7.8",
    "postgres": "^3.4.5",
    "zod": "^3.24.3"
  }
}
