{
  "name": "server",
  "module": "index.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "start": "bun run db-start && bun --watch index.ts",
    "dev": "concurrently \"bun run start\" \"bun run db-studio\"",
    "setup-dev": "bun run db-create && bun run db-seed",
    "db-start": "docker compose up -d postgres_db --wait",
    "db-create": "bun run db-start && bunx drizzle-kit generate --config \"db/drizzle.config.ts\" && bunx drizzle-kit push --config \"db/drizzle.config.ts\"",
    "db-reset": "docker compose down -v postgres_db && bun run db-create",
    "db-seed": "bun 'db/seed.ts' --rows 5000",
    "db-studio": "bunx drizzle-kit studio --config \"db/drizzle.config.ts\"",
    "build": "bun build index.ts --outdir dist --target bun"
  },
  "devDependencies": {
    "drizzle-kit": "^0.31.1"
  },
  "dependencies": {
    "@hono/zod-validator": "^0.5.0",
    "@turf/clusters-kmeans": "^7.2.0",
    "@turf/helpers": "^7.2.0",
    "drizzle-orm": "^0.43.1",
    "drizzle-seed": "^0.3.1",
    "hono": "^4.7.8",
    "postgres": "^3.4.5",
    "zod": "^3.24.3"
  }
}
